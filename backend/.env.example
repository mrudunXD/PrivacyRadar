# PrivacyRadar Backend — Environment Variables
# Copy this file to .env and fill in your API keys.

# ── AI Narrative ────────────────────────────────────────────────────────────
# Google Gemini API Key (free at https://aistudio.google.com/apikey)
# Without this, a smart rule-based fallback narrative is used automatically.
GEMINI_API_KEY=

# ── Breach Lookup APIs (HIBP) ───────────────────────────────────────────────
# HaveIBeenPwned API Key — enables REAL breach lookup for email addresses.
# Get a key at https://haveibeenpwned.com/API/Key (paid, ~$3.50/month)
HIBP_API_KEY=

# ── Free/Alternative Breach APIs ───────────────────────────────────────────
# XposedOrNot (Free, No Key required for 100 req/day)
# BreachDirectory (Free tier via RapidAPI - 50 req/month)
# Get a RapidAPI key at https://rapidapi.com/breachdirectory/api/breachdirectory
BREACH_DIRECTORY_API_KEY=
